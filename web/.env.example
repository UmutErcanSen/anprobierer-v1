# Vorlage. Echte Werte gehoeren in .env.local (wird nicht committed).
# Zu finden im Supabase-Dashboard unter Settings -> API Keys.

# Oeffentlich: landet im Browser-Bundle, unterliegt Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://xrintzcwgaiwgwnbqmxy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# GEHEIM: umgeht Row Level Security vollstaendig.
# Niemals mit NEXT_PUBLIC_ praefixen, niemals in Client-Komponenten importieren.
# Wird ausschliesslich in Route Handlern und Server Actions verwendet.
SUPABASE_SERVICE_ROLE_KEY=

# GEHEIM: Betreiber-Key fuer die Bildgenerierung (ab Phase 2).
# Ersetzt das bisherige BYOK-Modell - der Browser sieht diesen Key nie.
OPENAI_API_KEY=

# GEHEIM: ab Phase 3.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
